# ============================================================
# 千问 (DashScope) — LLM + Embedding
# ============================================================
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ============================================================
# Milvus 向量数据库 — RAG 检索引擎
# ============================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============================================================
# Redis — 短时记忆层
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# Kafka — 工作记忆层
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ============================================================
# MySQL — 长时记忆层
# ============================================================
MYSQL_URL=mysql://tourai:tourai123@localhost:3307/tourai
DATABASE_URL=mysql://tourai:tourai123@localhost:3307/tourai

# ============================================================
# PostgreSQL — LangGraph Checkpoint 持久化
# ============================================================
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/tourai

# ============================================================
# 和风天气 API — 真实天气数据 (免费1000次/天)
# 注册: https://dev.qweather.com/
# ============================================================
QWEATHER_API_KEY=

# ============================================================
# LangSmith 可观测性 — LangGraph 自动节点追踪 (5000 traces/月免费)
# 注册: https://smith.langchain.com/
# ============================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_xxx
LANGCHAIN_PROJECT=tour-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================
# Langfuse 可观测性 — LLM Token 用量监控
# 注册: https://cloud.langfuse.com/
# ============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================
# CRM
# ============================================================
CRM_API_URL=
CRM_API_KEY=
