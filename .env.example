# ============================================================
# 千问 (DashScope) - 推荐
# ============================================================
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型选择 (可选，默认用网关内置值)
# qwen-turbo  - 轻量路由 (意图识别)
# qwen-plus   - 主力模型 (客服/销售/运营)
# qwen-max    - 旗舰模型 (旅游定制/报价)
LLM_MODEL=qwen-plus

# ============================================================
# OpenAI 兼容 (备选)
# ============================================================
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# 数据库 (Phase 3)
# ============================================================
DATABASE_URL=postgresql://localhost:5432/tourai

# ============================================================
# Redis (Phase 3)
# ============================================================
REDIS_URL=redis://localhost:6379/0
MQ_URL=redis://localhost:6379/1

# ============================================================
# 外部 API (Phase 2)
# ============================================================
WEATHER_API_KEY=

# ============================================================
# CRM (Phase 3)
# ============================================================
CRM_API_URL=
CRM_API_KEY=

# ============================================================
# Langfuse (Phase 3)
# ============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
